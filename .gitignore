# =============================================================================
# Dependencies — regenerated from lockfiles, never committed
# =============================================================================
node_modules/
vendor/

# =============================================================================
# Build outputs — apps/wizard/dist is a build artefact.
# NOTE: plugins/quote-wizard/assets/dist/ IS committed (see ADR-0006).
# =============================================================================
apps/wizard/dist/
apps/wizard/.vite/
dist/
*.zip
!plugins/quote-wizard/assets/dist/

# =============================================================================
# Test & coverage outputs
# =============================================================================
coverage/
.nyc_output/
*.lcov

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Environment files (NEVER commit secrets)
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Editor / IDE
# =============================================================================
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# =============================================================================
# OS noise
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Local WordPress dev artefacts (in case anyone runs wp-env in-tree)
# =============================================================================
.wp-env.override.json
wp-env-home/
.local-wp/

# =============================================================================
# PHP tooling caches
# =============================================================================
.phpunit.result.cache
.phpunit.cache/
.phpcs-cache
.phpstan-cache/

# =============================================================================
# Husky — managed but its install state is local
# =============================================================================
.husky/_/
