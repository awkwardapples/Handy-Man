{
  "compilerOptions": {
    /* -----------------------------------------------------------
       Module / target
       Vite handles the actual transpilation; tsc is used for
       type-checking only (`tsc --noEmit`). Settings here must be
       compatible with what Vite produces.
       ----------------------------------------------------------- */
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,

    /* -----------------------------------------------------------
       JSX — react-jsx removes the need for `import React`
       in every file. Modern default for React 17+.
       ----------------------------------------------------------- */
    "jsx": "react-jsx",

    /* -----------------------------------------------------------
       Emit — Vite handles emission; tsc is type-check-only.
       ----------------------------------------------------------- */
    "noEmit": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,

    /* -----------------------------------------------------------
       Strict checks. Each of these is opinionated; each catches
       a real category of bug we'd rather find at compile time.
       ----------------------------------------------------------- */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,

    /* -----------------------------------------------------------
       Module interop — required for default imports from
       CommonJS dependencies (rare in our stack but defensive).
       ----------------------------------------------------------- */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    /* -----------------------------------------------------------
       Path aliases — @/foo resolves to src/foo.
       Mirrored in vite.config.ts and (later) in vitest config.
       ----------------------------------------------------------- */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
